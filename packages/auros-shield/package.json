{
  "name": "@adrien1212balitrand/auros-shield",
  "version": "0.3.0",
  "description": "AUROS Shield — on-prem cryptographic underlayer for RWA CFU/attest seals, CBOM and crypto-agility (PQC-ready envelopes)",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "auros-shield": "./bin/auros-shield.js"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": [
    "bin",
    "dist",
    "README.md",
    "Dockerfile"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/cli.ts src/server.ts --format esm --dts --clean",
    "start": "node -e \"import('./dist/server.js').then(m => m.startShieldServer(Number(process.env.PORT||8787)))\"",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "auros",
    "shield",
    "on-prem",
    "rwa",
    "attestation",
    "cbom",
    "post-quantum",
    "crypto-agility"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/getauros/auros",
    "directory": "packages/auros-shield"
  },
  "homepage": "https://getauros.com/developers/shield",
  "devDependencies": {
    "tsup": "^8.5.0",
    "typescript": "^5"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
