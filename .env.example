# --- IA dossier (Gemini free tier en premier — voir docs/AI-COSTS.md) ---
GEMINI_API_KEY=
GROQ_API_KEY=
MISTRAL_API_KEY=
# Ordre des providers (défaut: gemini,groq,mistral)
# AI_PROVIDER_ORDER=gemini,groq,mistral
# Mode gratuit uniquement (Gemini + template, pas de Groq/Mistral)
# AI_FREE_ONLY=true
# Mode économie (8B Groq, sections plus courtes) — désactivé par défaut = qualité
# AI_ECONOMY_MODE=true
# Plafond global générations / jour UTC (0 = illimité)
AI_DAILY_GENERATION_CAP=200
# Tokens max sortie (~80-120 mots × 6 sections)
AI_MAX_OUTPUT_TOKENS=1600
# Modèles (optionnel)
# GEMINI_MODEL=gemini-2.0-flash
# GROQ_DOSSIER_MODEL=llama-3.1-8b-instant
# MISTRAL_MODEL=open-mistral-nemo

# --- Clerk (auth) ---
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# --- Supabase (dossiers persistés) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SECRET_KEY=

# --- Site (liens partage) ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Resend (e-mails transactionnels) ---
RESEND_API_KEY=
# Dev: onboarding@resend.dev — only delivers to your Resend account email until domain verified
RESEND_FROM_EMAIL=onboarding@resend.dev
RESEND_INTERNAL_EMAIL=your@gmail.com

# --- Simulation / démo (pas d'appels IA facturables) ---
# Dev/staging only — NEVER true on Vercel production
# AUROS_SIMULATION=true
# --- Stripe (juridictions — machine à cash) ---
# Secret: Dashboard → Developers → API keys (sk_live_… — server only, never commit)
STRIPE_SECRET_KEY=
# Publishable (pk_live_…) — optional; Checkout redirect n'en a pas besoin côté client
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Webhook: Developers → Webhooks → endpoint /api/webhooks/stripe → whsec_…
STRIPE_WEBHOOK_SECRET=
# Vercel Cron — relances J+1 / J+3
CRON_SECRET=
# Green registry PDF HMAC footer (optional — falls back to CRON_SECRET, then SHA256 only)
GREEN_EXPORT_SIGNING_KEY=
# Ops inbox for weekly Green label CSV cron (falls back to RESEND_INTERNAL_EMAIL)
OPS_EMAIL=
# Weekly label export filter: all | incomplete (default: all)
# GREEN_LABEL_WEEKLY_EXPORT_FILTER=all

# Webhook ops (Slack / Make / Zapier) — alertes leads hot + paiements
JURISDICTION_WEBHOOK_URL=
JURISDICTION_WEBHOOK_SECRET=

# --- Optionnel ---
# SENTRY_AUTH_TOKEN=
# SENTRY_DSN=
