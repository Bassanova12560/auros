# --- IA dossier / Copilot (Gemini free tier en premier — voir docs/AI-COSTS.md) ---
GEMINI_API_KEY=
# Secours quota Gemini (failover 429)
# GEMINI_API_KEY_2=
GROQ_API_KEY=
MISTRAL_API_KEY=
# OpenRouter — modèles :free pour quota gratuit supplémentaire (Copilot + dossier fallback)
OPENROUTER_API_KEY=
# OPENROUTER_MODEL=google/gemma-2-9b-it:free
# Ordre des providers (défaut: gemini,groq,mistral,openrouter)
# AI_PROVIDER_ORDER=gemini,groq,mistral,openrouter
# Mode gratuit uniquement (Gemini + OpenRouter free, pas de Groq/Mistral payants)
# AI_FREE_ONLY=true
# Mode économie (8B Groq, sections plus courtes) — désactivé par défaut = qualité
# AI_ECONOMY_MODE=true
# Plafond global générations / jour UTC (0 = illimité)
AI_DAILY_GENERATION_CAP=200
# Tokens max sortie (~80-120 mots × 6 sections)
AI_MAX_OUTPUT_TOKENS=1600
# Modèles (optionnel)
# GEMINI_MODEL=gemini-2.0-flash
# GROQ_DOSSIER_MODEL=llama-3.1-8b-instant
# MISTRAL_MODEL=open-mistral-nemo

# --- Clerk (auth) ---
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# --- Supabase (dossiers persistés) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SECRET_KEY=

# --- Site (liens partage) ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Resend (e-mails transactionnels) ---
RESEND_API_KEY=
# Dev: onboarding@resend.dev — only delivers to your Resend account email until domain verified
RESEND_FROM_EMAIL=onboarding@resend.dev
RESEND_INTERNAL_EMAIL=your@gmail.com

# --- Simulation / démo (pas d'appels IA facturables) ---
# Dev/staging only — NEVER true on Vercel production
# AUROS_SIMULATION=true
# --- Stripe (server only — never commit real keys) ---
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
# Green registry PDF HMAC (optional)
GREEN_EXPORT_SIGNING_KEY=
# Dedicated HMAC for attestations / ChargeFlow / Shield (preferred over CRON_SECRET)
ATTEST_SIGNING_KEY=
# Vercel Cron auth (server only)
CRON_SECRET=
# Ops UI session (preferred). Unlock at /ops/login → HttpOnly cookie. Falls back to CRON_SECRET if unset.
OPS_SESSION_SECRET=
# Lab ledger cookie HMAC (preferred). Soft-binds lab accountId. Falls back to CRON_SECRET / dev key.
ARL_LAB_SIGNING_KEY=
# Ops inbox for weekly Green label CSV cron (falls back to RESEND_INTERNAL_EMAIL)
OPS_EMAIL=
# Optional external waitlist form (Academy Praticien) — skips in-app form when set
TALLY_URL=
# Weekly label export filter: all | incomplete (default: all)
# GREEN_LABEL_WEEKLY_EXPORT_FILTER=all

# Webhook ops (Slack / Make / Zapier) — alertes leads hot + paiements
JURISDICTION_WEBHOOK_URL=
JURISDICTION_WEBHOOK_SECRET=

# --- Optionnel ---
# UPSTASH_REDIS_REST_URL=   # durable rate limits (Green anon, IP burst, /api/eau/check)
# UPSTASH_REDIS_REST_TOKEN=
# SENTRY_AUTH_TOKEN=
# SENTRY_DSN=               # error monitoring (instrumentation.ts)
