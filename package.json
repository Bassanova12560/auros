    "db:bootstrap:green-registry": "npx tsx scripts/run-green-registry-bootstrap.ts",
    "db:bootstrap:green-phase3": "npx tsx scripts/run-green-phase3-bootstrap.ts",
    "db:bootstrap:green-market": "npx tsx scripts/run-green-market-bootstrap.ts",
    "green:sync": "npx tsx scripts/run-green-market-bootstrap.ts",
    "green:health": "npx tsx scripts/green-health.ts --prod",
    "green:deploy": "npm run test:green && npm run build && npx vercel --prod --yes && npm run green:sync",
    "green:publish-sdk": "npm publish ./packages/auros-green --access public",
    "green:sync-stripe": "npx tsx scripts/sync-stripe-vercel.ts",
    "green:sync-clerk": "npx tsx scripts/sync-clerk-vercel.ts",
