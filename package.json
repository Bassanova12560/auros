    "nanoid": "^3.3.12",
    "next": "^16.2.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "resend": "^6.12.3",
    "stripe": "^22.2.0",
    "zod": "^3.25.76"
  },
